APP_NAME=TalentGraph
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000

# LLM_PROVIDER supports "ollama" or "claude".
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Required only when LLM_PROVIDER=claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

QDRANT_URL=http://localhost:6333
SQLITE_PATH=data/talentgraph.sqlite3

